 		delay 1000
 		println("$name | starts ")
 		request robotactor -m cmd : cmd(w,500)
 		 
 	}
 	Transition t0
 		whenReply cmddone   -> goon
 		whenReply cmdfailed -> goon
 		
 	State goon{
 		printCurrentMessage color magenta
 		[# System.exit(0) #]
 	}
 }
